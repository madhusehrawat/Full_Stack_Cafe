<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cart - Full Stack Cafe</title>
    <link rel="stylesheet" href="/css/cart.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<%- include('partials/navbar') %>

<div id="app-content">
    <input type="hidden" id="is-user-logged-in" value="<%= user ? 'true' : 'false' %>">
    
    <div id="cart-page-wrapper" style="max-width: 1200px; margin: 40px auto; padding: 0 20px;">
        <div class="cart-container" style="display: flex; gap: 30px; align-items: flex-start;">
            
            <div id="cart-main-section" style="flex: 2;">
                <h2 style="color: var(--main); margin-bottom: 25px; border-bottom: 2px solid #f8f8f8; padding-bottom: 15px;">
                    <i class="fas fa-shopping-basket" style="color: var(--accent);"></i> Your Selection
                </h2>
                <div id="items-wrapper">
                    </div>
            </div>

            <div id="cart-summary-section" style="flex: 1; position: sticky; top: 100px;">
                <div id="summary-card" style="background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid #eee;">
                    <h3 style="margin-top: 0; color: var(--main);">Order Summary</h3>
                    
                    <div class="summary-line" style="display: flex; justify-content: space-between; margin: 15px 0; color: #666;">
                        <span>Subtotal</span>
                        <span id="cartSubtotal">₹0.00</span>
                    </div>
                    <div class="summary-line" style="display: flex; justify-content: space-between; margin: 15px 0; color: #666;">
                        <span>GST (5%)</span>
                        <span id="cartTax">₹0.00</span>
                    </div>
                    
                    <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
                    
                    <div class="total-line" style="font-size: 1.4rem; font-weight: 800; display: flex; justify-content: space-between; color: var(--main);">
                        <span>Total</span>
                        <span id="cartGrandTotal">₹0.00</span>
                    </div>

                    <button id="checkoutBtn" class="confirm-btn" style="width: 100%; margin-top: 25px; padding: 16px; background: var(--accent); color: white; border: none; border-radius: 10px; font-size: 1rem; font-weight: bold; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 15px rgba(230, 126, 34, 0.3);">
                        Confirm Order (COD)
                    </button>
                    
                    <p style="text-align: center; font-size: 0.8rem; color: #999; margin-top: 15px;">
                        <i class="fas fa-shield-alt"></i> Secure Checkout
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>
    (function() {
        const getCart = () => JSON.parse(localStorage.getItem('cafe_cart')) || [];
        const saveCart = (cart) => {
            localStorage.setItem('cafe_cart', JSON.stringify(cart));
            if (typeof window.updateCartBadge === 'function') window.updateCartBadge();
        };

        const renderCart = () => {
            const cart = getCart();
            const wrapper = document.getElementById('items-wrapper');
            const summaryCol = document.getElementById('cart-summary-section');
            const mainCol = document.getElementById('cart-main-section');
            let subtotal = 0;

            if (cart.length === 0) {
                if(summaryCol) summaryCol.style.display = 'none';
                if(mainCol) mainCol.style.flex = '1';
                wrapper.innerHTML = `
                    <div class="empty-cart-msg" style="text-align:center; padding: 80px 20px; background: white; border-radius: 15px;">
                        <i class="fas fa-mug-hot" style="font-size: 5rem; color: #eee; margin-bottom: 25px;"></i>
                        <h3 style="color: #888;">Your tray is empty</h3>
                        <p style="color: #bbb; margin-bottom: 30px;">Add some delicious items from our menu!</p>
                        <a href="/products" class="spa-link" style="background: var(--main); color: white; padding: 12px 25px; border-radius: 8px; text-decoration: none; font-weight: bold;">Browse Menu</a>
                    </div>`;
                return;
            }

            if(summaryCol) summaryCol.style.display = 'block';
            
            wrapper.innerHTML = cart.map(item => {
                const total = item.price * item.quantity;
                subtotal += total;
                return `
                    <div class="item-row" style="display: flex; align-items: center; gap: 20px; padding: 20px; background: white; border-radius: 12px; margin-bottom: 15px; border: 1px solid #f0f0f0;">
                        <div class="item-img">
                            <img src="/images/${item.image}" 
                                 alt="${item.name}" 
                                 style="width: 90px; height: 90px; object-fit: cover; border-radius: 10px;"
                                 onerror="this.src='https://placehold.co/100x100?text=Food'">
                        </div>
                        <div class="item-info" style="flex: 1;">
                            <h4 style="margin:0; font-size: 1.1rem; color: var(--main);">${item.name}</h4>
                            <p style="color:#888; margin:5px 0 0; font-size: 0.9rem;">₹${item.price} per unit</p>
                        </div>
                        <div class="qty-controls" style="display: flex; align-items: center; gap: 15px; background: #f8f8f8; padding: 5px 12px; border-radius: 30px;">
                            <button class="qty-btn-minus" data-id="${item.id}" style="border:none; background:none; cursor:pointer; font-weight:bold; color:var(--main);">-</button>
                            <strong style="min-width: 20px; text-align: center;">${item.quantity}</strong>
                            <button class="qty-btn-plus" data-id="${item.id}" style="border:none; background:none; cursor:pointer; font-weight:bold; color:var(--main);">+</button>
                        </div>
                        <div class="item-total" style="min-width: 90px; text-align: right; font-weight: 800; color: var(--main);">
                            ₹${total.toFixed(2)}
                        </div>
                    </div>`;
            }).join('');

            const tax = subtotal * 0.05;
            document.getElementById('cartSubtotal').innerText = "₹" + subtotal.toFixed(2);
            document.getElementById('cartTax').innerText = "₹" + tax.toFixed(2);
            document.getElementById('cartGrandTotal').innerText = "₹" + (subtotal + tax).toFixed(2);
        };

        const handleQtyChange = (id, change) => {
            let cart = getCart();
            const idx = cart.findIndex(i => i.id === id);
            if (idx > -1) {
                cart[idx].quantity += change;
                if (cart[idx].quantity <= 0) cart.splice(idx, 1);
                saveCart(cart);
                renderCart();
            }
        };

        const processCheckout = async () => {
            const cart = getCart();
            const isLoggedIn = document.getElementById('is-user-logged-in').value === 'true';

            if (!isLoggedIn) {
                alert("Please login to place your order.");
                if(typeof window.navigate === 'function') return window.navigate("/login?returnTo=/cart");
                window.location.href = "/login?returnTo=/cart";
                return;
            }

            const btn = document.getElementById('checkoutBtn');
            btn.disabled = true;
            btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Processing...`;
            
            try {
                const res = await fetch('/cart/confirm', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cartItems: cart })
                });
                const data = await res.json();
                
                if (data.success) {
                    localStorage.removeItem('cafe_cart');
                    // Use the SPA navigate function for a smooth transition
                    if(typeof window.navigate === 'function') {
                        window.navigate("/orders");
                    } else {
                        window.location.href = "/orders";
                    }
                } else {
                    alert(data.message || "Checkout failed");
                    btn.disabled = false;
                    btn.innerText = "Confirm Order (COD)";
                }
            } catch (e) { 
                alert("Error connecting to server"); 
                btn.disabled = false; 
                btn.innerText = "Confirm Order (COD)";
            }
        };

        // Event Delegation
        document.getElementById('items-wrapper').addEventListener('click', (e) => {
            const btn = e.target.closest('button');
            if (!btn) return;
            const id = btn.dataset.id;
            if (btn.classList.contains('qty-btn-minus')) handleQtyChange(id, -1);
            if (btn.classList.contains('qty-btn-plus')) handleQtyChange(id, 1);
        });

        document.getElementById('checkoutBtn').addEventListener('click', processCheckout);

        renderCart();
    })();
    </script>
</div>
</body>

<%- include('partials/footer') %>
</html>