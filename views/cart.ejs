<%- include('partials/navbar') %>

<style>
    :root { --main: #5d4037; --accent: #e67e22; --bg: #fdf5e6; }
    
    .qty-btn { 
        width: 32px; height: 32px; border-radius: 8px; 
        border: 1px solid #ddd; cursor: pointer; background: #fff; 
        transition: 0.2s; font-weight: bold;
    }
    .qty-btn:hover { background: var(--bg); border-color: var(--main); }
    
    .item-row { 
        display: flex; align-items: center; background: #fff; 
        padding: 15px; border-radius: 10px; margin-bottom: 15px; 
        box-shadow: 0 2px 8px rgba(0,0,0,0.1); 
    }

    .empty-cart-msg {
        text-align: center; padding: 60px 20px; background: white; 
        border-radius: 15px; border: 2px dashed #ddd;
    }
    
    .browse-link {
        display: inline-block; margin-top: 15px; padding: 10px 25px;
        background: var(--main); color: white !important;
        text-decoration: none; border-radius: 8px; font-weight: bold;
    }

    /* Spinner Animation */
    .spinner {
        display: inline-block;
        width: 18px; height: 18px;
        border: 3px solid rgba(255,255,255,.3);
        border-radius: 50%;
        border-top-color: #fff;
        animation: spin 1s ease-in-out infinite;
        margin-right: 10px;
        vertical-align: middle;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
</style>

<div id="app-content">
    <div class="cart-container" style="display: flex; gap: 30px; padding: 40px 5%; max-width: 1200px; margin: auto; align-items: flex-start;">
        
        <div style="flex: 2;">
            <h2 style="color: #5d4037; border-bottom: 2px solid #5d4037; padding-bottom: 10px;">
                <i class="fas fa-shopping-basket"></i> Your Selection
            </h2>
            <div id="items-wrapper"></div>
        </div>

        <div style="flex: 1; position: sticky; top: 100px;">
            <div id="summary-card" style="background: #fff; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); transition: 0.3s;">
                <h3 style="margin: 0 0 15px; color: #5d4037;">Order Summary</h3>
                <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                    <span>Subtotal</span> <span id="cartSubtotal">₹0.00</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                    <span>GST (5%)</span> <span id="cartTax">₹0.00</span>
                </div>
                <hr style="border: 0; border-top: 1px solid #eee;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 25px; font-size: 1.3rem; font-weight: bold; color: var(--main);">
                    <span>Total</span> <span id="cartGrandTotal">₹0.00</span>
                </div>
                <button id="checkoutBtn" onclick="confirmOrder()" style="width: 100%; background: #2e7d32; color: white; border: none; padding: 16px; border-radius: 10px; font-weight: bold; cursor: pointer; font-size: 1rem; transition: 0.3s;">
                    Confirm Order (COD)
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function getCart() {
        try { return JSON.parse(localStorage.getItem('cafe_cart')) || []; } catch (e) { return []; }
    }

    function saveAndRender(cart) {
        localStorage.setItem('cafe_cart', JSON.stringify(cart));
        renderCart();
        updateCartBadge();
    }

    function renderCart() {
        const cart = getCart();
        const wrapper = document.getElementById('items-wrapper');
        const checkoutBtn = document.getElementById('checkoutBtn');
        let subtotal = 0;

        if (cart.length === 0) {
            wrapper.innerHTML = `
                <div class="empty-cart-msg">
                    <h3 style="color:#888; margin:0;">Your tray is empty</h3>
                    <p style="color:#aaa;">Add some delicious items from our menu!</p>
                    <a href="/products" class="browse-link">Go to Menu →</a>
                </div>`;
            document.getElementById('cartSubtotal').innerText = "₹0.00";
            document.getElementById('cartTax').innerText = "₹0.00";
            document.getElementById('cartGrandTotal').innerText = "₹0.00";
            checkoutBtn.disabled = true;
            checkoutBtn.style.background = "#ccc";
            return;
        }

        checkoutBtn.disabled = false;
        checkoutBtn.style.background = "#2e7d32";

        wrapper.innerHTML = cart.map(item => {
            const itemTotal = (item.price * item.quantity);
            subtotal += itemTotal;
            return `
                <div class="item-row">
                    <div style="flex: 1;">
                        <h4 style="margin:0; color:var(--main);">${item.name}</h4>
                        <p style="color:#777; margin:5px 0 0; font-size:0.9rem;">₹${item.price} / unit</p>
                    </div>
                    <div style="display:flex; align-items:center; gap:15px; margin-right:20px;">
                        <button class="qty-btn" onclick="updateQty('${item.id}', -1)">-</button>
                        <strong style="width:20px; text-align:center;">${item.quantity}</strong>
                        <button class="qty-btn" onclick="updateQty('${item.id}', 1)">+</button>
                    </div>
                    <div style="font-weight:bold; min-width:80px; text-align:right;">₹${itemTotal.toFixed(2)}</div>
                </div>`;
        }).join('');

        const tax = subtotal * 0.05;
        document.getElementById('cartSubtotal').innerText = `₹${subtotal.toFixed(2)}`;
        document.getElementById('cartTax').innerText = `₹${tax.toFixed(2)}`;
        document.getElementById('cartGrandTotal').innerText = `₹${(subtotal + tax).toFixed(2)}`;
    }

    function updateQty(id, change) {
        let cart = getCart();
        const index = cart.findIndex(i => i.id === id);
        if (index > -1) {
            cart[index].quantity += change;
            if (cart[index].quantity <= 0) cart.splice(index, 1);
            saveAndRender(cart);
        }
    }

    async function confirmOrder() {
        const cart = getCart();
        const btn = document.getElementById('checkoutBtn');
        const summary = document.getElementById('summary-card');
        
        if (cart.length === 0) return;

        // UI Feedback: Start Loading
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span>Processing...';
        summary.style.opacity = "0.7";

        try {
            const res = await fetch('/cart/confirm', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cartItems: cart })
            });
            const data = await res.json();
            
            if (data.success) {
                localStorage.removeItem('cafe_cart');
                updateCartBadge();
                window.location.href = "/orders";
            } else {
                alert(data.message || "Order failed");
                resetBtn(btn, summary);
            }
        } catch (err) {
            alert("Connection error.");
            resetBtn(btn, summary);
        }
    }

    function resetBtn(btn, summary) {
        btn.disabled = false;
        btn.innerHTML = "Confirm Order (COD)";
        summary.style.opacity = "1";
    }

    function updateCartBadge() {
        const cart = JSON.parse(localStorage.getItem('cafe_cart')) || [];
        const count = cart.reduce((sum, item) => sum + (Number(item.quantity) || 0), 0);
        const badge = document.getElementById('cartBadge');
        if (badge) {
            badge.innerText = count;
            badge.style.display = count > 0 ? 'inline-block' : 'none';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        renderCart();
        updateCartBadge();
    });
</script>

<%- include('partials/footer') %>