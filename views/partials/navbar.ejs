<style>
    :root {
        --main: #5d4037;
        --accent: #e67e22;
        --accent-hover: #cf711f;
        --white: #ffffff;
        --glass: rgba(255, 255, 255, 0.08);
    }

    #loading-bar {
        position: fixed; top: 0; left: 0; width: 0%; height: 3px;
        background: linear-gradient(to right, var(--accent), #ff9800);
        z-index: 9999; transition: width 0.4s ease, opacity 0.4s ease;
        box-shadow: 0 0 10px rgba(230, 126, 34, 0.5);
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .fade-in { animation: fadeIn 0.5s ease forwards; }

    nav {
        background: linear-gradient(135deg, #5d4037, #4e342e);
        padding: 14px 6%; display: flex; justify-content: space-between;
        align-items: center; color: var(--white); box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        position: sticky; top: 0; z-index: 1000;
    }

    .logo { font-size: 24px; font-weight: 700; text-decoration: none; color: white; transition: 0.3s; }
    .logo span { color: var(--accent); }

    .nav-menu { display: flex; align-items: center; gap: 10px; }
    .nav-menu a { text-decoration: none; color: white; padding: 8px 16px; border-radius: 8px; font-weight: 500; transition: 0.3s; }
    .nav-menu a:hover { background: var(--glass); transform: translateY(-2px); }
    .nav-menu a.active { background: var(--accent); }

    .cart-container { position: relative; display: flex; align-items: center; }
    .cart-badge {
        position: absolute; top: -5px; right: -5px; 
        background: var(--accent); color: white; font-size: 10px; 
        width: 18px; height: 18px; border-radius: 50%;
        display: none; align-items: center; justify-content: center;
        font-weight: 700; border: 2px solid #5d4037;
    }

    .user-section { display: flex; align-items: center; gap: 15px; }
    .user-info { display: flex; align-items: center; gap: 10px; background: var(--glass); padding: 6px 14px; border-radius: 30px; }
    
    .avatar { 
        width: 35px; height: 35px; background: linear-gradient(135deg, #e67e22, #ff9800);
        border-radius: 50%; display: flex; justify-content: center; align-items: center;
        font-weight: bold; color: white;
    }

    .btn { padding: 8px 18px; border-radius: 8px; text-decoration: none; font-weight: 600; transition: 0.3s; border: none; cursor: pointer;}
    .btn-logout { background: #e74c3c; color: white; }
    .btn-logout:hover { background: #c0392b; }

    @media (max-width: 768px) {
        .username { display: none; }
        .nav-menu a { padding: 8px 10px; font-size: 14px; }
    }
</style>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div id="loading-bar"></div>
<nav>
    <a href="/products" class="logo spa-link">☕ FullStack <span>Cafe</span></a>

    <div class="nav-menu">
        <% if(user && user.role === 'admin') { %>
            <a href="/admin" class="spa-link">Dashboard</a>
        <% } else { %>
            <a href="/products" class="spa-link">Products</a>
            <a href="/support" class="spa-link">Support</a>
            <a href="/orders" class="spa-link">My Orders</a>
            <a href="/cart" class="cart-container spa-link">
                <i class="fas fa-shopping-cart"></i>
                <span id="cartBadge" class="cart-badge">0</span>
            </a>
        <% } %>
    </div>

    <div class="user-section">
        <% if (user) { %>
            <div class="user-info">
                <div class="avatar"><%= user.username.charAt(0).toUpperCase() %></div>
                <span class="username" style="color:white;"><%= user.username %></span>
            </div>
            <a href="/logout" class="btn btn-logout">Logout</a>
        <% } else { %>
            <a href="/login" class="btn spa-link" style="color:white;">Login</a>
            <a href="/signup" class="btn spa-link" style="background: var(--accent); color: white;">Signup</a>
        <% } %>
    </div>
</nav>

<script>
// Logic remains robust and unchanged, as it was already well-written!
window.updateCartBadge = function() {
    const badge = document.getElementById('cartBadge');
    if (!badge) return; 
    const cart = JSON.parse(localStorage.getItem('cafe_cart')) || [];
    const count = cart.reduce((sum, item) => sum + (item.quantity || 0), 0);
    badge.textContent = count;
    badge.style.display = count > 0 ? 'flex' : 'none';
};

const loader = {
    bar: document.getElementById('loading-bar'),
    start() { this.bar.style.cssText = 'opacity: 1; width: 30%;'; },
    stop() { 
        this.bar.style.width = '100%';
        setTimeout(() => { this.bar.style.cssText = 'opacity: 0; width: 0%;'; }, 400);
    }
};

async function navigate(url, isBack = false) {
    const content = document.getElementById('app-content');
    if (!content) return window.location.href = url;

    try {
        loader.start();
        const res = await fetch(url);
        if (res.redirected) return window.location.href = res.url;
        
        const html = await res.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const newHtml = doc.getElementById('app-content');

        if (newHtml) {
            content.style.opacity = '0';
            setTimeout(() => {
                content.innerHTML = newHtml.innerHTML;
                if (!isBack) window.history.pushState({}, '', url);
                document.title = doc.title;
                
                content.querySelectorAll('script').forEach(oldScript => {
                    const newScript = document.createElement('script');
                    Array.from(oldScript.attributes).forEach(a => newScript.setAttribute(a.name, a.value));
                    newScript.textContent = oldScript.textContent;
                    oldScript.replaceWith(newScript);
                });

                window.updateCartBadge();
                content.style.opacity = '1';
                content.classList.add('fade-in');
                window.scrollTo(0, 0);
                loader.stop();
            }, 100);
        } else {
            window.location.href = url;
        }
    } catch (e) { window.location.href = url; }
}

document.addEventListener('click', async e => {
    const link = e.target.closest('.spa-link');
    const logoutBtn = e.target.closest('.btn-logout'); // Target the logout button specifically

    // --- LOGOUT CONFIRMATION LOGIC ---
    if (logoutBtn) {
        e.preventDefault();
        
        const result = await Swal.fire({
            title: 'Leaving so soon?',
            text: "Are you sure you want to logout from FullStack Cafe?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#e67e22', // Matches your --accent
            cancelButtonColor: '#5d4037',  // Matches your --main
            confirmButtonText: 'Yes, logout',
            background: '#fff',
            borderRadius: '15px'
        });

        if (result.isConfirmed) {
            loader.start();
            try {
                const res = await fetch('/logout', {
                    headers: { 'Accept': 'application/json' }
                });
                const data = await res.json();
                
                if (data.success) {
                    // Clear local storage if needed (like your cafe_cart)
                    // localStorage.removeItem('cafe_cart'); 
                    window.location.href = data.redirectUrl;
                }
            } catch (err) {
                window.location.href = '/logout'; // Fallback
            }
        }
        return;
    }

    // --- EXISTING SPA NAVIGATION LOGIC ---
    if (!link || !link.href.startsWith(window.location.origin)) return;
    e.preventDefault();
    navigate(link.href);
});

window.onpopstate = () => navigate(window.location.href, true);
document.addEventListener('DOMContentLoaded', window.updateCartBadge);
</script>