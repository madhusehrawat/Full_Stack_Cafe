<style>
    :root {
        --main: #5d4037;
        --accent: #e67e22;
        --accent-hover: #cf711f;
        --white: #ffffff;
        --glass: rgba(255, 255, 255, 0.08);
    }
    #loading-bar {
        position: fixed;
        top: 0;
        left: 0;
        width: 0%;
        height: 3px;
        background: linear-gradient(to right, var(--accent), #ff9800);
        z-index: 9999;
        transition: width 0.4s ease, opacity 0.4s ease;
        box-shadow: 0 0 10px rgba(230, 126, 34, 0.5);
    }

    .fade-in {
        animation: fadeIn 0.5s ease forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    /* Navbar Container */
    nav {
        background: linear-gradient(135deg, #5d4037, #4e342e);
        padding: 14px 6%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--white);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    /* Logo */
    .logo {
        font-size: 24px;
        font-weight: 700;
        text-decoration: none;
        color: white;
        letter-spacing: 0.5px;
        transition: 0.3s;
    }

    .logo span {
        color: var(--accent);
    }

    .logo:hover {
        transform: scale(1.05);
    }

    /* Menu Links */
    .nav-menu {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .nav-menu a {
        text-decoration: none;
        color: white;
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .nav-menu a:hover {
        background: var(--glass);
        backdrop-filter: blur(5px);
        transform: translateY(-2px);
    }

    .nav-menu a.active {
        background: var(--accent);
        color: white;
    }


    /* Cart Badge Styling */
    .cart-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .cart-badge {
        position: absolute;
        top: -8px;
        right: -8px;
        background: var(--accent);
        color: white;
        font-size: 11px;
        padding: 2px 6px;
        border-radius: 50%;
        font-weight: 700;
        border: 2px solid #5d4037;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }

    /* User Section */
    .user-section {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--glass);
        padding: 6px 14px;
        border-radius: 30px;
        transition: 0.3s;
    }

    .avatar {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, #e67e22, #ff9800);
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: bold;
        font-size: 17px;
        color: white;
        box-shadow: 0 3px 8px rgba(0, 0, 0, 0.2);
    }

    .username {
        font-weight: 500;
        font-size: 15px;
    }

    /* Buttons */
    .btn {
        padding: 8px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-login { color: white; }
    .btn-login:hover { background: var(--glass); }

    .btn-signup, .btn-logout {
        background: linear-gradient(135deg, #e67e22, #ff9800);
        color: white;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);
    }

    .btn-signup:hover, .btn-logout:hover {
        background: linear-gradient(135deg, #cf711f, #e68900);
        transform: translateY(-2px);
    }

    @media (max-width: 768px) {
        .username { display: none; }
        .nav-menu { gap: 5px; }
        .nav-menu a { padding: 6px 10px; font-size: 14px; }
    }
</style>


<div id="loading-bar"></div>
<nav>
    <a href="/products" class="logo spa-link">
        ☕ FullStack <span>Cafe</span>
    </a>

    <div class="nav-menu">
        <a href="/products" class="spa-link">Products</a>
        <a href="/support" class="spa-link">Support</a>

        <% if (user) { %>
            <a href="/orders" class="spa-link">My Orders</a>
            <a href="/cart" class="cart-container spa-link">
                <i class="fas fa-shopping-cart"></i>
                <span id="cartBadge" class="cart-badge">
                    <%= (typeof cartCount !== 'undefined') ? cartCount : 0 %>
                </span>
            </a>
            
            <% if (user.role === 'admin') { %>
                <a href="/admin/dashboard" class="spa-link" style="color: #ffab91; font-weight: bold;">
                    <span class="pulse-dot"></span> Cafe Control Hub
                </a>
            <% } %>
        <% } %> 
    </div>

    <div class="user-section">
        <% if (user) { %>
            <div class="user-info">
                <div class="avatar">
                    <%= (user.username) ? user.username.charAt(0).toUpperCase() : '?' %>
                </div>
                <span class="username text-white"><%= user.username %></span>
            </div>
            <a href="/logout" class="btn btn-logout">Logout</a>
        <% } else { %>
            <a href="/login" class="btn btn-login spa-link">Login</a>
            <a href="/signup" class="btn btn-signup spa-link">Signup</a>
        <% } %>
    </div>
</nav>
<script>
const loadingBar = document.getElementById('loading-bar');

function startLoading() {
    loadingBar.style.opacity = '1';
    loadingBar.style.width = '30%';
}

function stopLoading() {
    loadingBar.style.width = '100%';
    setTimeout(() => {
        loadingBar.style.opacity = '0';
        setTimeout(() => { loadingBar.style.width = '0%'; }, 400);
    }, 200);
}

document.addEventListener('click', async (e) => {
    const link = e.target.closest('.spa-link');
    if (!link || !link.href || link.href.includes('#')) return;
    
    // Safety: If it's a cross-origin link or a logout link, do a normal redirect
    if (!link.href.includes(window.location.origin) || link.href.includes('/logout')) return;
    
    e.preventDefault();
    const url = link.href;

    try {
        startLoading();
        document.body.style.cursor = 'wait';

        const response = await fetch(url);
        
        // ✅ CRITICAL FIX: If the response redirected us (e.g., login successful), 
        // perform a hard redirect to refresh the Navbar and User permissions.
        if (response.redirected) {
            window.location.href = response.url;
            return;
        }

        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');

        const newContent = doc.getElementById('app-content');
        const currentContent = document.getElementById('app-content');

        if (newContent && currentContent) {
            currentContent.style.opacity = '0';

            setTimeout(() => {
                currentContent.innerHTML = newContent.innerHTML;
                
                // Refresh Page State
                window.history.pushState({}, '', url);
                document.title = doc.title;
                
                // Update active link styling
                document.querySelectorAll('.nav-menu a').forEach(a => a.classList.remove('active'));
                link.classList.add('active');

                // Re-run scripts in the new content
                const scripts = currentContent.querySelectorAll("script");
                scripts.forEach(oldScript => {
                    const newScript = document.createElement("script");
                    Array.from(oldScript.attributes).forEach(attr => newScript.setAttribute(attr.name, attr.value));
                    newScript.appendChild(document.createTextNode(oldScript.innerHTML));
                    oldScript.parentNode.replaceChild(newScript, oldScript);
                });

                currentContent.style.opacity = '1';
                currentContent.classList.add('fade-in');
                window.scrollTo(0, 0);
                stopLoading();
            }, 150);
        } else {
            window.location.href = url;
        }
    } catch (err) {
        window.location.href = url;
    } finally {
        document.body.style.cursor = 'default';
    }
});

// Refresh page on back/forward button to keep user state synced
window.onpopstate = () => location.reload();
</script>