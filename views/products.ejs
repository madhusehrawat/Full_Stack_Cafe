<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FullStack Cafe | Products</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

    <style>
        :root { 
            --main: #4e342e; 
            --accent: #d35400; 
            --bg: #fdf5e6; 
            --white: #ffffff;
            --text: #2c3e50;
            --outOfStock: #95a5a6;
            --shadow: 0 10px 30px rgba(0,0,0,0.08);
            --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        body { font-family: 'Poppins', sans-serif; background: var(--bg); margin: 0; color: var(--text); overflow-x: hidden; }

        /* --- Header --- */
        .header { text-align: center; padding: 50px 20px 30px; background: linear-gradient(to bottom, #f3e5f5, var(--bg)); }
        .header h1 { font-family: 'Playfair Display', serif; color: var(--main); font-size: 2.8rem; margin: 0; }
        .header p { color: #6d4c41; margin-top: 5px; }

        /* --- Filters & Tabs --- */
        .category-tabs { text-align: center; margin-bottom: 20px; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px; }
        .category-tabs button { padding: 8px 20px; border-radius: 30px; border: 2px solid var(--main); cursor: pointer; background: transparent; color: var(--main); font-weight: 600; transition: var(--transition); }
        .category-tabs button.active { background: var(--main); color: white; }

        .availability-tabs { text-align: center; margin-bottom: 30px; }
        .avail-group { display: inline-flex; background: white; padding: 4px; border-radius: 40px; box-shadow: var(--shadow); border: 1px solid #eee; }
        .tab-mini { padding: 6px 15px; border-radius: 30px; border: none; cursor: pointer; font-weight: 600; background: transparent; color: var(--text); font-size: 0.85rem; transition: 0.3s; }
        .tab-mini.active { background: var(--accent); color: white; }

        .filters { display: flex; justify-content: center; max-width: 450px; margin: 0 auto 40px; position: relative; }
        .filters input { padding: 12px 20px; width: 100%; border-radius: 40px; border: 1px solid #ddd; outline: none; box-shadow: var(--shadow); }
        .filters button { position: absolute; right: 5px; top: 4px; padding: 8px 15px; background: var(--accent); color: white; border-radius: 30px; border: none; cursor: pointer; }

        /* --- Product Grid --- */
        .product-grid {
            max-width: 1200px; 
            margin: 0 auto; 
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 25px; 
            padding: 20px;
            transition: opacity 0.3s ease;
        }

        .card { 
            background: var(--white); border-radius: 15px; overflow: hidden; 
            box-shadow: var(--shadow); transition: var(--transition); 
            display: flex; flex-direction: column; cursor: pointer;
        }
        .card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,0.1); }

        .card-image-container { position: relative; width: 100%; height: 180px; overflow: hidden; background: #f9f9f9; }
        .card img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease; }
        .card:hover img { transform: scale(1.08); }

        .sold-out-overlay {
            position: absolute; inset: 0; background: rgba(255, 255, 255, 0.6);
            display: flex; justify-content: center; align-items: center; z-index: 10; 
            font-weight: 700; color: #c0392b; font-size: 1.1rem; text-transform: uppercase; backdrop-filter: blur(1px);
        }

        .card-body { padding: 18px; text-align: left; }
        .card-body h3 { margin: 0 0 5px; font-size: 1.1rem; color: var(--main); font-weight: 600; }
        
        .stock-badge { display: inline-block; font-size: 0.65rem; padding: 2px 8px; border-radius: 8px; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
        .in-stock { background: #e8f5e9; color: #2e7d32; }
        .out-of-stock { background: #ffebee; color: #c62828; }

        .price { color: var(--accent); font-size: 1.25rem; font-weight: 700; margin-bottom: 15px; }

        .buy-btn { 
            background: var(--main); color: white; border: none; padding: 10px; border-radius: 10px; 
            cursor: pointer; width: 100%; font-weight: 600; display: flex; align-items: center; 
            justify-content: center; gap: 8px; font-size: 0.9rem; transition: 0.3s;
        }
        .buy-btn:hover:not(:disabled) { background: var(--accent); }
        .buy-btn:disabled { background: var(--outOfStock); cursor: not-allowed; }

        /* --- Pagination Modern Navigation --- */
        .pagination-container { display: flex; justify-content: center; margin: 50px 0 80px; }
        .pagination-wrapper { 
            display: flex; align-items: center; background: var(--white); 
            padding: 8px 15px; border-radius: 50px; box-shadow: var(--shadow); 
            gap: 20px; border: 1px solid #eee; 
        }
        .nav-btn { 
            background: var(--main); color: white; border: none; 
            width: 38px; height: 38px; border-radius: 50%; cursor: pointer; 
            display: flex; align-items: center; justify-content: center; transition: 0.3s; 
        }
        .nav-btn:hover:not(:disabled) { background: var(--accent); transform: scale(1.1); }
        .nav-btn:disabled { background: #e0e0e0; color: #999; cursor: not-allowed; }
        .page-counter { font-weight: 600; color: var(--main); display: flex; align-items: center; gap: 8px; min-width: 70px; justify-content: center; }
        .page-counter .divider { color: #ccc; }
        .page-counter .total { color: #999; }

        /* --- Modal --- */
        .modal-overlay { 
            position: fixed; inset: 0; background: rgba(0,0,0,0.5); 
            display: none; justify-content: center; align-items: center; z-index: 2000; 
            backdrop-filter: blur(4px);
        }
        .modal-content { 
            background: white; width: 90%; max-width: 700px; border-radius: 20px; 
            padding: 30px; position: relative; display: flex; gap: 30px; 
        }
        .modal-img-wrapper { flex: 0 0 250px; height: 250px; border-radius: 15px; overflow: hidden; }
        .modal-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }

        @media (max-width: 600px) {
            .modal-content { flex-direction: column; align-items: center; text-align: center; }
            .modal-img-wrapper { flex: 0 0 200px; width: 200px; }
        }
    </style>
</head>
<body>

<%- include('partials/navbar', { user }) %>

<div id="app-content">
    <div class="header">
        <h1>FullStack Cafe Menu</h1>
        <p>Handcrafted beverages and premium bites.</p>
    </div>

    <div class="category-tabs">
        <% 
           let activeCat = locals.category || ''; 
           ['All', 'Coffee', 'Drinks', 'Junk Food', 'Salad', 'Dessert'].forEach(cat => { 
                const catValue = cat === 'All' ? '' : cat.toLowerCase();
                const isActive = (catValue === activeCat) ? 'active' : '';
        %>
            <button class="<%= isActive %>" onclick="loadProducts({category: '<%= catValue %>', page: 1})">
                <%= cat %>
            </button>
        <% }) %>
    </div>

    <div class="availability-tabs">
        <% let activeAvail = locals.availability || ''; %>
        <div class="avail-group">
            <button id="avail-all" class="tab-mini <%= !activeAvail ? 'active' : '' %>" 
                    onclick="loadProducts({availability: '', page: 1})">All Items</button>
            <button id="avail-instock" class="tab-mini <%= activeAvail === 'instock' ? 'active' : '' %>" 
                    onclick="loadProducts({availability: 'instock', page: 1})">In Stock</button>
            <button id="avail-outofstock" class="tab-mini <%= activeAvail === 'outofstock' ? 'active' : '' %>" 
                    onclick="loadProducts({availability: 'outofstock', page: 1})">Out of Stock</button>
        </div>
    </div>

    <div class="filters">
        <input type="text" id="searchInput" placeholder="Search menu..." value="<%= locals.search || '' %>" onkeyup="if(event.key==='Enter') triggerSearch()">
        <button onclick="triggerSearch()"><i class="fas fa-search"></i></button>
    </div>

    <div class="product-grid" id="productGrid">
        <% if (locals.items && items.length > 0) { %>
            <% items.forEach(p => { 
                const isOutOfStock = p.countInStock <= 0;
            %>
                <div class="card" onclick="openProductModal('<%= p._id %>', '<%= p.name %>', '<%= p.price %>', '<%= p.image %>', '<%= p.category %>', `<%= p.description %>`, <%= isOutOfStock %>)">
                    <div class="card-image-container">
                        <% if (isOutOfStock) { %><div class="sold-out-overlay">Sold Out</div><% } %>
                        <img src="/images/<%= p.image %>" alt="<%= p.name %>" loading="lazy">
                    </div>
                    <div class="card-body">
                        <span class="stock-badge <%= isOutOfStock ? 'out-of-stock' : 'in-stock' %>">
                            <i class="fas <%= isOutOfStock ? 'fa-times' : 'fa-check' %>"></i>
                            <%= isOutOfStock ? 'Unavailable' : 'In Stock' %>
                        </span>
                        <h3><%= p.name %></h3>
                        <div class="price">₹<%= p.price %></div>
                        <button class="buy-btn" <%= isOutOfStock ? 'disabled' : '' %> 
                                onclick="event.stopPropagation(); addToLocalStorage('<%= p._id %>', '<%= p.name %>', '<%= p.price %>', '<%= p.image %>')">
                            <% if(isOutOfStock) { %>
                                <i class="fas fa-bell"></i> Notify Me
                            <% } else { %>
                                <i class="fas fa-plus"></i> Add to bag
                            <% } %>
                        </button>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="grid-column: 1/-1; text-align: center; padding: 80px 20px; color: #999;">
                <i class="fas fa-mug-hot" style="font-size: 3rem; margin-bottom: 15px; opacity: 0.3;"></i>
                <p style="font-size: 1.1rem;">No items found matching your filters.</p>
                <button onclick="loadProducts({category: '', availability: '', search: ''})" style="background:none; border:none; color:var(--accent); text-decoration:underline; cursor:pointer;">Clear all filters</button>
            </div>
        <% } %>
    </div>

    <% if (locals.totalPages > 1) { %>
    <div class="pagination-container" id="paginationBox">
        <div class="pagination-wrapper">
            <button class="nav-btn" <%= currentPage === 1 ? 'disabled' : '' %> onclick="loadProducts({page: <%= currentPage - 1 %>})">
                <i class="fas fa-chevron-left"></i>
            </button>
            <div class="page-counter">
                <span class="current"><%= currentPage %></span>
                <span class="divider">/</span>
                <span class="total"><%= totalPages %></span>
            </div>
            <button class="nav-btn" <%= currentPage === totalPages ? 'disabled' : '' %> onclick="loadProducts({page: <%= currentPage + 1 %>})">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </div>
    <% } %>
</div>

<div id="productModal" class="modal-overlay" onclick="closeModal()">
    <div class="modal-content" onclick="event.stopPropagation()">
        <span style="position: absolute; top: 15px; right: 20px; font-size: 2rem; cursor: pointer; color: #999;" onclick="closeModal()">&times;</span>
        <div class="modal-img-wrapper">
            <img id="modalImg" src="">
        </div>
        <div style="flex: 1; display: flex; flex-direction: column; justify-content: center;">
            <h2 id="modalTitle" style="font-family: 'Playfair Display', serif; font-size: 1.8rem; margin: 0 0 10px; color: var(--main);"></h2>
            <p id="modalDescription" style="color: #666; font-size: 0.95rem; margin-bottom: 20px; line-height: 1.5;"></p>
            <div id="modalPrice" style="font-size: 1.6rem; font-weight: 700; color: var(--accent); margin-bottom: 25px;"></div>
            <button id="modalAddBtn" class="buy-btn" style="padding: 14px; font-size: 1rem;"></button>
        </div>
    </div>
</div>

<script>
    async function loadProducts(newParams = {}) {
        const grid = document.getElementById('productGrid');
        const pagBox = document.getElementById('paginationBox');
        const urlParams = new URLSearchParams(window.location.search);
        
        Object.keys(newParams).forEach(k => { 
            if (newParams[k] === '') urlParams.delete(k); 
            else urlParams.set(k, newParams[k]); 
        });

        const newUrl = `/products?${urlParams.toString()}`;
        grid.style.opacity = '0.4';

        try {
            const res = await fetch(newUrl);
            const html = await res.text();
            const doc = new DOMParser().parseFromString(html, 'text/html');
            
            // Replace Content
            grid.innerHTML = doc.getElementById('productGrid').innerHTML;
            
            const newPag = doc.getElementById('paginationBox');
            if(pagBox && newPag) pagBox.innerHTML = newPag.innerHTML;
            else if(!pagBox && newPag) document.getElementById('app-content').appendChild(newPag);
            else if(pagBox && !newPag) pagBox.remove();

            // Sync Tabs
            const activeCat = urlParams.get('category') || '';
            document.querySelectorAll('.category-tabs button').forEach(btn => {
                btn.classList.toggle('active', btn.getAttribute('onclick').includes(`'${activeCat}'`));
            });

            const activeAvail = urlParams.get('availability') || '';
            document.getElementById('avail-all').classList.toggle('active', activeAvail === '');
            document.getElementById('avail-instock').classList.toggle('active', activeAvail === 'instock');
            document.getElementById('avail-outofstock').classList.toggle('active', activeAvail === 'outofstock');

            window.history.pushState({}, '', newUrl);
        } catch (e) {
            window.location.href = newUrl; 
        } finally {
            grid.style.opacity = '1';
        }
    }

    function triggerSearch() {
        loadProducts({ search: document.getElementById('searchInput').value, page: 1 });
    }

    function openProductModal(id, name, price, image, category, desc, isOut) {
        document.getElementById('modalTitle').innerText = name;
        document.getElementById('modalPrice').innerText = `₹${price}`;
        document.getElementById('modalDescription').innerText = (desc && desc !== 'undefined') ? desc : "A FullStack Cafe special.";
        document.getElementById('modalImg').src = `/images/${image}`;
        const btn = document.getElementById('modalAddBtn');
        if(isOut) {
            btn.disabled = true;
            btn.innerHTML = `<i class="fas fa-ban"></i> Temporarily Unavailable`;
        } else {
            btn.disabled = false;
            btn.innerHTML = `<i class="fas fa-cart-plus"></i> Add to Tray - ₹${price}`;
            btn.onclick = () => { addToLocalStorage(id, name, price, image); closeModal(); };
        }
        document.getElementById('productModal').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        document.getElementById('productModal').style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    function addToLocalStorage(id, name, price, image) {
        let cart = JSON.parse(localStorage.getItem('cafe_cart')) || [];
        const idx = cart.findIndex(i => i.id === id);
        if (idx > -1) cart[idx].quantity += 1;
        else cart.push({ id, name, price: parseFloat(price), image, quantity: 1 });
        localStorage.setItem('cafe_cart', JSON.stringify(cart));
        if(window.updateCartBadge) window.updateCartBadge();
        alert(`${name} added!`);
    }

    window.onclick = (e) => { if(e.target.id === 'productModal') closeModal(); }
</script>
<%-include('partials/footer') %>
</body>
</html>